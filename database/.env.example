# Required: database connection.
# Used by migrations, seed scripts, crawler, and hourly pipeline.
DATABASE_URL=postgresql://<username>:<password>@<host>/<dbname>?sslmode=require

# Optional: realtime notification bridge from Database pipeline -> Backend -> Frontend.
# BACKEND_NOTIFICATION_PUSH_URL is called after rows are created in notifications/user_notifications.
# BACKEND_INTERNAL_SECRET must match INTERNAL_API_SECRET in backend/.env.
BACKEND_NOTIFICATION_PUSH_URL=http://localhost:8000/api/v1/internal/notifications/push
BACKEND_INTERNAL_SECRET=change_me

# Optional: latest arXiv crawler query override.
# Leave blank to use the default latest query built from the 10 configured topics
# in database/crawler/arxiv_client.py.
# Example:
# ARXIV_LATEST_QUERY=cat:cs.AI OR cat:cs.LG OR cat:cs.CL
ARXIV_LATEST_QUERY=
